<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Myapp" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Favicon -->
    <%= favicon_link_tag "favicon.png" %>

    <%= yield :head %>

    <!-- OGP -->
    <meta property="og:title" content="言語化トレーニングジム">
    <meta property="og:description" content="AIフィードバックで伝わる説明力を鍛える言語化トレーニングアプリ">
    <meta property="og:image" content="<%= image_url('ogp.png') %>">
    <meta property="og:url" content="<%= root_url %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="言語化トレーニングジム">

    <!-- twitter(X)用OGP -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="言語化トレーニングジム">
    <meta name="twitter:description" content="AIフィードバックで伝わる説明力を鍛える言語化トレーニングアプリ">
    <meta name="twitter:image" content="<%= image_url('ogp.png') %>">

    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" href="favicon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <main class="min-h-screen">
      <% flash.each do |type, message| %>
      <% bg_class =
          type == "notice" ?
          "bg-green-50 border-green-200 text-green-700" :
          "bg-red-50 border-red-200 text-red-700" %>

      <div class="mx-auto max-w-4xl mt-4 px-4">
        <div class="rounded-lg border px-4 py-3 <%= bg_class %>">
          <%= message %>
        </div>
      </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
