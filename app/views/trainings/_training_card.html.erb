<div class="bg-white rounded-2xl shadow-md hover:shadow-lg transition p-6 h-full border border-gray-100">

  <div class="flex justify-end mb-2">
    <% if current_user.favorite_trainings.exists?(training.id) %>

        <%= button_to training_favorite_path(training),
        method: :delete,
        class: "text-yellow-400 text-xl" do %>
        ★
        <% end %>

    <% else %>

        <%= button_to training_favorite_path(training),
        method: :post,
        class: "text-gray-300 hover:text-yellow-400 text-xl" do %>
        ☆
        <% end %>

    <% end %>
  </div>

  <!-- 日付 -->
  <p class="text-sm text-gray-400 mb-4">
    <%= training.created_at.strftime("%Y/%m/%d") %>
  </p>

  <!-- テーマ -->
  <div class="mb-5">
    <p class="text-xs text-gray-500 mb-1">
      テーマ
    </p>

    <h2 class="truncate text-lg font-bold text-gray-800 break-words">
      <%= training.theme %>
    </h2>
  </div>

  <!-- 相手とスコア -->
  <div class="flex justify-between gap-4">

    <div class="min-w-0 mb-5">
      <p class="text-xs text-gray-500">
        説明相手
      </p>

      <p class="truncate text-gray-800">
        <%= training.display_target %>
      </p>
    </div>

    <div class="shrink-0 text-right">
      <p class="text-xs text-gray-500">
        スコア
      </p>

      <p class="font-semibold text-amber-600">
        <%= training.ai_feedback&.score || "-" %>点
      </p>
    </div>
  </div>

  <!-- 説明内容 -->
  <div>
    <p class="text-xs text-gray-500 mb-1">
      説明内容
    </p>

    <p class="text-sm text-gray-700 leading-relaxed">
      <%= truncate(training.explanation, length: 80) %>
    </p>
  </div>

  <div class="mt-4 flex justify-end">
    <%= link_to "詳細を見る →", training_path(training), class: "inline-flex items-center text-sm font-semibold text-amber-600 hover:text-amber-700" %>
  </div>
</div>
