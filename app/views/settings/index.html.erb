<h1 class="text-2xl font-bold text-amber-500 mb-6">
  ⚙️ 設定
</h1>

<div class="space-y-4">

  <%= link_to "#",
      class: "block bg-white rounded-2xl shadow-md p-5 hover:bg-gray-50 transition" do %>
    <p class="font-semibold">アカウント設定</p>
    <p class="text-sm text-gray-500">
      ユーザー名やパスワードを変更
    </p>
  <% end %>

  <%= link_to terms_path,
      class: "block bg-white rounded-2xl shadow-md p-5 hover:bg-gray-50 transition" do %>
    <p class="font-semibold">利用規約</p>
    <p class="text-sm text-gray-500">
      利用規約を確認
    </p>
  <% end %>

  <%= link_to privacy_policy_path,
      class: "block bg-white rounded-2xl shadow-md p-5 hover:bg-gray-50 transition" do %>
    <p class="font-semibold">プライバシーポリシー</p>
    <p class="text-sm text-gray-500">
      個人情報の取り扱いについて
    </p>
  <% end %>

  <%= link_to "#",
      class: "block bg-white rounded-2xl shadow-md p-5 hover:bg-gray-50 transition" do %>
    <p class="font-semibold">お問い合わせ（準備中）</p>
    <p class="text-sm text-gray-500">
      お問い合わせフォームへ
    </p>
  <% end %>

  <%= link_to "#",
      class: "block bg-red-50 rounded-2xl shadow-md p-5 hover:bg-red-100 transition border border-red-200" do %>
    <p class="font-semibold text-red-600">
      アカウント削除
    </p>
    <p class="text-sm text-gray-500">
      アカウントおよび関連データを削除します
    </p>
  <% end %>

</div>