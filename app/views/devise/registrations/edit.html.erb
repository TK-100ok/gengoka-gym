<div class="max-w-2xl mx-auto">

  <h1 class="text-2xl font-bold text-amber-500 mb-6">
    ⚙️ アカウント設定
  </h1>

  <% if resource.errors.any? %>
    <div class="mb-6 rounded-lg bg-red-100 border border-red-300 px-4 py-3 text-red-700">
      入力内容に誤りがあります
    </div>
  <% end %>

  <%= form_for(
    resource,
    as: resource_name,
    url: registration_path(resource_name),
    html: { method: :put }
  ) do |f| %>

    <!-- ユーザー名 -->
    <div class="mb-5">
      <%= f.label :name, "ユーザー名", class: "block font-medium mb-2" %>
      <%= f.text_field :name, class: "bg-white w-full rounded-lg px-4 py-2 #{resource.errors[:name].any? ? 'border border-red-500' : 'border border-gray-300'}" %>
      <% if resource.errors[:name].any? %>
        <p class="text-sm text-red-500 mt-1">
          <%= resource.errors.full_messages_for(:name).join(", ") %>
        </p>
      <% end %>
    </div>

    <!-- メールアドレス -->
    <div class="mb-5">
      <label class="block font-medium mb-2">
        メールアドレス
      </label>

      <input
        type="email"
        value="<%= current_user.email %>"
        disabled
        class="w-full rounded-lg border border-gray-300 px-4 py-2 bg-gray-100 text-gray-500"
      >
    </div>

    <h2 class="font-semibold mb-4">
      パスワード変更
    </h2>

    <!-- 新しいパスワード -->
    <div class="mb-5">
      <%= f.label :password, "新しいパスワード", class: "block font-medium mb-2" %>
      <%= f.password_field :password, autocomplete: "new-password", class: "bg-white w-full rounded-lg border border-gray-300 px-4 py-2" %>
      <% if resource.errors[:password].any? %>
        <p class="text-sm text-red-500 mt-1">
          <%= resource.errors.full_messages_for(:password).join(", ") %>
        </p>
      <% end %>
    </div>

    <!-- 確認 -->
    <div class="mb-5">
      <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "block font-medium mb-2" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "bg-white w-full rounded-lg border border-gray-300 px-4 py-2" %>
      <% if resource.errors[:password_confirmation].any? %>
        <p class="text-sm text-red-500 mt-1">
          <%= resource.errors.full_messages_for(:password_confirmation).join(", ") %>
        </p>
      <% end %>
    </div>

    <!-- 現在のパスワード -->
    <div class="mb-6">
      <%= f.label :current_password, "現在のパスワード", class: "block font-medium mb-2" %>
      <%= f.password_field :current_password, autocomplete: "current-password", class: "bg-white w-full rounded-lg border border-gray-300 px-4 py-2" %>
      <% if resource.errors[:current_password].any? %>
        <p class="text-sm text-red-500 mt-1">
          <%= resource.errors.full_messages_for(:current_password).join(", ") %>
        </p>
      <% end %>
      <p class="text-sm text-gray-500 mt-1">
        変更内容を保存するために必要です
      </p>
    </div>

    <%= f.submit "保存する",
        class: "bg-amber-400 hover:bg-amber-500 text-white px-6 py-2 rounded-lg" %>

  <% end %>

</div>
