<h1 class="text-2xl font-bold text-amber-500 mb-6">
  ⭐ お気に入り
</h1>

<%= render("shared/search_form",
  q: @q,
  url: favorites_path,
  search_key: :theme_or_explanation_or_target_name_cont,
  sort_options: [
    ["作成日（降順）", "created_at desc"],
    ["作成日（昇順）", "created_at asc"],
    ["スコア（降順）", "ai_feedback_score desc"],
    ["スコア（昇順）", "ai_feedback_score asc"]
  ]) %>

<% if @trainings.any? %>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
    <% @trainings.each do |training| %>
      <%= render "trainings/training_card", training: training %>
    <% end %>
  </div>

<% else %>

  <p class="text-gray-400">
    お気に入りはまだありません
  </p>

<% end %>

<%= paginate @trainings %>
